{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Telegram": {
    "ApiBaseUrl": "https://api.telegram.org",
    "PollingTimeoutSeconds": 30,
    "WebApiBaseUrl": "http://localhost:5001",
    "NotifierHttpTimeoutSeconds": 60,
    "WebApiHttpTimeoutSeconds": 180,
    "PollingErrorRetrySeconds": 5,
    "OnDemandMaxRetries": 3,
    "OnDemandRetryBaseDelaySeconds": 2
  }
}
