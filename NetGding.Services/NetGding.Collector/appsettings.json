{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Collector": {
    "UsePaper": true,
    "Symbols": [
      "BTC/USD",
      "ETH/USD",
      "SOL/USD",
      "PAXG/USD"
    ],
    "BarTimeFrames": ["15m", "1h", "4h", "1d", "1w", "1m"],
    "LookbackDays": 5,
    "OutputDirectory": "collected-data",
    "NewsEnabled": true,
    "NewsPollingIntervalMinutes": 5,
    "NewsLookbackHours": 24,
    "AnalysisEnabled": true,
    "GemmaBaseUrl": "https://openrouter.ai/api/v1", "note": "change to local host if using local gemma",
    "GemmaModel": "google/gemma-4-26b-a4b-it:free",
    "WebApiPublishEnabled": false,
    "WebApiBaseUrl": "http://localhost:5001",
    "WebApiHttpTimeoutSeconds": 30,
    "AutoAnalysisDelaySeconds": 8,
    "AnalysisCollectionOffsetSeconds": 30,
    "AnalysisIdlePollMinutes": 1,
    "PublishMaxRetries": 3
  }
}